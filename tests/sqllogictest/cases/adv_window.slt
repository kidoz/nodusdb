# Phase 6 (advanced): window functions.

statement ok
CREATE TABLE scores (id INT PRIMARY KEY, team TEXT, pts INT);

statement ok
INSERT INTO scores VALUES (1, 'a', 10), (2, 'a', 30), (3, 'b', 20), (4, 'b', 50), (5, 'b', 5);

# ROW_NUMBER within a partition
query ITI
SELECT id, team, ROW_NUMBER() OVER (PARTITION BY team ORDER BY pts DESC) AS rn FROM scores ORDER BY team, pts DESC;
----
2	a	1
1	a	2
4	b	1
3	b	2
5	b	3

# SUM over a partition (whole-partition frame)
query TII rowsort
SELECT team, pts, SUM(pts) OVER (PARTITION BY team) AS total FROM scores;
----
a	10	40
a	30	40
b	20	75
b	5	75
b	50	75

# LAG over an ordering
query II
SELECT id, LAG(pts) OVER (ORDER BY id) FROM scores ORDER BY id;
----
1	NULL
2	10
3	30
4	20
5	50
