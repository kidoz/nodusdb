# Coverage GAP: EXISTS / NOT EXISTS (correlated subqueries) are NOT evaluated —
# the predicate is treated as always-true and returns every row. The equivalent
# IN / NOT IN subquery form works and is the current substitute.

statement ok
CREATE TABLE t (id INT PRIMARY KEY, v INT);

statement ok
INSERT INTO t VALUES (1, 10), (2, 20), (3, 30);

statement ok
CREATE TABLE u (tid INT);

statement ok
INSERT INTO u VALUES (1), (3);

# IN-subquery substitute for EXISTS
query I rowsort
SELECT id FROM t WHERE id IN (SELECT tid FROM u);
----
1
3

# NOT IN substitute for NOT EXISTS
query I rowsort
SELECT id FROM t WHERE id NOT IN (SELECT tid FROM u);
----
2
