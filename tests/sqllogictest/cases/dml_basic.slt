# Phase 4 (DML): INSERT / UPDATE / DELETE round-trips.

statement ok
CREATE TABLE t (id INT PRIMARY KEY, name TEXT, n INT);

# insert: positional, explicit column list, multi-row
statement ok
INSERT INTO t VALUES (1, 'a', 10);

statement ok
INSERT INTO t (id, name, n) VALUES (2, 'b', 20);

statement ok
INSERT INTO t VALUES (3, 'c', 30), (4, 'd', 40);

query ITI
SELECT id, name, n FROM t ORDER BY id;
----
1	a	10
2	b	20
3	c	30
4	d	40

# update a single column
statement ok
UPDATE t SET n = 99 WHERE id = 1;

query I
SELECT n FROM t WHERE id = 1;
----
99

# update multiple columns
statement ok
UPDATE t SET name = 'x', n = 100 WHERE id = 2;

query TI
SELECT name, n FROM t WHERE id = 2;
----
x	100

# update with an expression in SET
statement ok
UPDATE t SET n = n + 5 WHERE id = 3;

query I
SELECT n FROM t WHERE id = 3;
----
35

# delete
statement ok
DELETE FROM t WHERE id = 4;

query I
SELECT count(*) FROM t;
----
3

# delete with a predicate matching nothing leaves the table intact
statement ok
DELETE FROM t WHERE id = 999;

query I
SELECT count(*) FROM t;
----
3
