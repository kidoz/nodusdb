# Phase 3 (DQL): subqueries — IN / NOT IN / scalar / derived table.

statement ok
CREATE TABLE t (id INT, val INT);

statement ok
INSERT INTO t VALUES (1, 10), (2, 20), (3, 30), (4, 40);

# IN (subquery)
query I rowsort
SELECT id FROM t WHERE val IN (SELECT val FROM t WHERE val > 20);
----
3
4

# NOT IN (subquery)
query I rowsort
SELECT id FROM t WHERE val NOT IN (SELECT val FROM t WHERE val > 20);
----
1
2

# NOTE: scalar subquery in WHERE (`val = (SELECT max(val) FROM t)`) is a known
# gap — NodusDB only evaluates IN-subqueries; a scalar-subquery comparison is
# treated as always-true and returns every row. Omitted here, tracked as a gap.

# derived table (subquery in FROM)
query I rowsort
SELECT x.id FROM (SELECT id FROM t WHERE val > 20) x;
----
3
4
