# A PK-less table keys rows by the whole row, so rows that share a value in one
# column no longer collide on insert (PostgreSQL allows duplicate rows).

statement ok
CREATE TABLE nopk (region TEXT, amount INT);

statement ok
INSERT INTO nopk VALUES ('west', 100), ('west', 200), ('east', 50);

query I
SELECT count(*) FROM nopk;
----
3

query I rowsort
SELECT amount FROM nopk WHERE region = 'west';
----
100
200

# update one of the same-region rows
statement ok
UPDATE nopk SET amount = 999 WHERE region = 'west' AND amount = 100;

query I rowsort
SELECT amount FROM nopk WHERE region = 'west';
----
200
999

# delete one row
statement ok
DELETE FROM nopk WHERE amount = 200;

query I
SELECT count(*) FROM nopk;
----
2

# an index-less table allows exact-duplicate rows (heap semantics)
statement ok
CREATE TABLE dup (a INT, b TEXT);

statement ok
INSERT INTO dup VALUES (1, 'x'), (1, 'x'), (1, 'x');

query I
SELECT count(*) FROM dup;
----
3

# they update and delete like any rows
statement ok
UPDATE dup SET b = 'y' WHERE a = 1;

query TI
SELECT b, count(*) FROM dup GROUP BY b;
----
y	3

statement ok
DELETE FROM dup WHERE a = 1;

query I
SELECT count(*) FROM dup;
----
0
