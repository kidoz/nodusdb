# Baseline regression cases: NodusDB behaviors verified (2026-07-15) to match
# PostgreSQL today. This is deliberately narrow — it pins the surface that
# currently works so it cannot regress.
#
# NOT included yet (blocked on a known engine gap): any SELECT that computes a
# value in the target list — arithmetic (2 + 3), CAST (x::float8), comparisons
# (a = b), string concat, or ordinary function calls (upper, length, abs). The
# projection evaluator does not evaluate these; it returns int4 0 / the function
# name / a DB error. See the compatibility report. Those cases land once the
# projection evaluator is implemented.

# --- Bare literals (typed correctly) ---
query I
SELECT 1;
----
1

query R
SELECT 1.5;
----
1.5

query BB
SELECT true, false;
----
t	f

# --- Column projection, filtering, ordering ---
statement ok
CREATE TABLE t (id INT, name TEXT);

statement ok
INSERT INTO t VALUES (1, 'alice'), (3, 'carol'), (2, 'bob');

query IT
SELECT id, name FROM t ORDER BY id;
----
1	alice
2	bob
3	carol

query T
SELECT name FROM t WHERE id = 2;
----
bob

query I rowsort
SELECT id FROM t WHERE id > 1;
----
2
3

# --- Aggregates that work today (avg is intentionally omitted; it returns NULL) ---
query I
SELECT count(*) FROM t;
----
3

query III
SELECT sum(id), min(id), max(id) FROM t;
----
6	1	3
