# Ported from PostgreSQL src/test/regress/sql/limit.sql (curated subset).
# pg's file pages through onek; this port keeps the LIMIT/OFFSET construct
# coverage on a compact ordered fixture.

statement ok
CREATE TABLE limit_tbl (unique1 INT, unique2 INT);

statement ok
INSERT INTO limit_tbl VALUES
  (0, 998), (1, 214), (2, 326), (3, 459), (4, 601),
  (5, 87), (6, 978), (7, 647), (8, 653), (9, 49);

# LIMIT alone
query I
SELECT unique1 FROM limit_tbl ORDER BY unique1 LIMIT 2;
----
0
1

# OFFSET alone
query I
SELECT unique1 FROM limit_tbl ORDER BY unique1 OFFSET 8;
----
8
9

# LIMIT + OFFSET
query II
SELECT unique1, unique2 FROM limit_tbl ORDER BY unique1 LIMIT 3 OFFSET 4;
----
4	601
5	87
6	978

# OFFSET beyond the row count yields nothing
query I
SELECT unique1 FROM limit_tbl ORDER BY unique1 OFFSET 20;
----

# LIMIT 0 yields nothing
query I
SELECT unique1 FROM limit_tbl ORDER BY unique1 LIMIT 0;
----

# LIMIT with a WHERE filter
query I
SELECT unique1 FROM limit_tbl WHERE unique1 > 4 ORDER BY unique1 LIMIT 2;
----
5
6

# LIMIT under DESC ordering
query II
SELECT unique1, unique2 FROM limit_tbl ORDER BY unique2 DESC LIMIT 3;
----
0	998
6	978
8	653

# LIMIT applies after aggregation/grouping
statement ok
CREATE TABLE limit_grp (g INT, v INT);

statement ok
INSERT INTO limit_grp VALUES (1, 1), (1, 2), (2, 3), (2, 4), (3, 5);

query II
SELECT g, sum(v) FROM limit_grp GROUP BY g ORDER BY g LIMIT 2;
----
1	3
2	7
