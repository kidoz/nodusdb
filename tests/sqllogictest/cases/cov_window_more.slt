# Coverage: more window functions.

statement ok
CREATE TABLE w (id INT PRIMARY KEY, grp TEXT, val INT);

statement ok
INSERT INTO w VALUES (1, 'a', 10), (2, 'a', 30), (3, 'b', 20), (4, 'b', 20), (5, 'b', 5);

# DENSE_RANK (ties share a rank, no gaps)
query ITI
SELECT id, grp, DENSE_RANK() OVER (PARTITION BY grp ORDER BY val DESC) FROM w ORDER BY grp, val DESC, id;
----
2	a	1
1	a	2
3	b	1
4	b	1
5	b	2

# FIRST_VALUE over a partition
query ITI
SELECT id, grp, FIRST_VALUE(val) OVER (PARTITION BY grp ORDER BY val DESC) FROM w ORDER BY grp, val DESC, id;
----
2	a	30
1	a	30
3	b	20
4	b	20
5	b	20

# NOTE: NTILE(), and frame clauses (ROWS/RANGE BETWEEN), are not yet supported.
