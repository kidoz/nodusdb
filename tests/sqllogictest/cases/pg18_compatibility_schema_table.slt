# PostgreSQL 18 Compatibility Suite
# Focus: Schema, Table operations, and Basic DML

# 1. Schema Operations
statement ok
CREATE SCHEMA pg18_test_schema;

# 2. Table Operations within Schema
statement ok
CREATE TABLE pg18_test_schema.users (
    id INT PRIMARY KEY,
    username TEXT,
    email TEXT,
    created_at TIMESTAMP
);

statement ok
CREATE TABLE pg18_test_schema.orders (
    order_id INT PRIMARY KEY,
    user_id INT,
    total_amount FLOAT
);

# 3. DML Operations (Work with tables)
statement ok
INSERT INTO pg18_test_schema.users (id, username, email, created_at) VALUES (1, 'alice', 'alice@example.com', '2026-01-01 10:00:00');

statement ok
INSERT INTO pg18_test_schema.users (id, username, email, created_at) VALUES (2, 'bob', 'bob@example.com', '2026-01-02 11:30:00');

statement ok
INSERT INTO pg18_test_schema.orders (order_id, user_id, total_amount) VALUES (101, 1, 49.99);

statement ok
INSERT INTO pg18_test_schema.orders (order_id, user_id, total_amount) VALUES (102, 2, 89.50);

# Basic Selects
query ITTT
SELECT id, username, email, created_at FROM pg18_test_schema.users ORDER BY id;
----
1 alice alice@example.com 2026-01-01 10:00:00
2 bob bob@example.com 2026-01-02 11:30:00

query IIF
SELECT order_id, user_id, total_amount FROM pg18_test_schema.orders ORDER BY order_id;
----
101 1 49.99
102 2 89.50

# Updates
statement ok
UPDATE pg18_test_schema.users SET email = 'alice_new@example.com' WHERE id = 1;

query T
SELECT email FROM pg18_test_schema.users WHERE id = 1;
----
alice_new@example.com

# Deletes
statement ok
DELETE FROM pg18_test_schema.orders WHERE order_id = 101;

query I
SELECT COUNT(*) FROM pg18_test_schema.orders;
----
1

# 4. Alter Table Operations
statement ok
ALTER TABLE pg18_test_schema.users ADD COLUMN status TEXT;

statement ok
UPDATE pg18_test_schema.users SET status = 'active';

query IT
SELECT id, status FROM pg18_test_schema.users ORDER BY id;
----
1 active
2 active

statement ok
ALTER TABLE pg18_test_schema.users RENAME COLUMN status TO account_status;

query IT
SELECT id, account_status FROM pg18_test_schema.users ORDER BY id;
----
1 active
2 active

statement ok
ALTER TABLE pg18_test_schema.users DROP COLUMN email;

# Try renaming the table
statement ok
ALTER TABLE pg18_test_schema.users RENAME TO customers;

query IT
SELECT id, username FROM pg18_test_schema.customers ORDER BY id;
----
1 alice
2 bob

# 5. Drop Table and Schema Operations
statement ok
DROP TABLE pg18_test_schema.customers;

statement ok
DROP TABLE pg18_test_schema.orders;

statement ok
DROP SCHEMA pg18_test_schema;
