# Explicit NULLS FIRST / NULLS LAST overrides on ORDER BY. The default is nulls
# first on ASC and nulls last on DESC; an explicit clause overrides that.

statement ok
CREATE TABLE n (id INT PRIMARY KEY, v INT);

statement ok
INSERT INTO n VALUES (1, 10), (2, NULL), (3, 30), (4, NULL), (5, 20);

# Default ASC: nulls first.
query I
SELECT v FROM n ORDER BY v ASC;
----
NULL
NULL
10
20
30

# ASC NULLS LAST: override pushes nulls to the end.
query I
SELECT v FROM n ORDER BY v ASC NULLS LAST;
----
10
20
30
NULL
NULL

# Default DESC: nulls last.
query I
SELECT v FROM n ORDER BY v DESC;
----
30
20
10
NULL
NULL

# DESC NULLS FIRST: override pulls nulls to the front.
query I
SELECT v FROM n ORDER BY v DESC NULLS FIRST;
----
NULL
NULL
30
20
10

# NULLS override also works on an aggregate result column.
query II
SELECT v, count(*) FROM n GROUP BY v ORDER BY v ASC NULLS LAST;
----
10	1
20	1
30	1
NULL	2
