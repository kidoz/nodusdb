# Coverage: ORDER BY ... NULLS FIRST / NULLS LAST.

statement ok
CREATE TABLE nn (id INT PRIMARY KEY, v INT);

statement ok
INSERT INTO nn VALUES (1, 10), (2, NULL), (3, 5);

query I
SELECT id FROM nn ORDER BY v NULLS FIRST;
----
2
3
1

# NodusDB orders NULLs first on ASC and last on DESC by default (matching the
# NULLS FIRST/DESC-NULLS-LAST cases). An explicit NULLS clause that overrides the
# default (e.g. `ASC NULLS LAST`) is NOT yet honored — tracked as a gap.
query I
SELECT id FROM nn ORDER BY v DESC NULLS LAST;
----
1
3
2
