# INSERT ... ON CONFLICT (upsert) is supported: a key collision is resolved by
# the ON CONFLICT clause rather than raising a primary-key violation.

statement ok
CREATE TABLE k (id INT PRIMARY KEY, name TEXT);

statement ok
INSERT INTO k VALUES (1, 'a');

# DO NOTHING is a no-op on a key clash (the existing row is kept).
statement ok
INSERT INTO k VALUES (1, 'b') ON CONFLICT (id) DO NOTHING;

query T
SELECT name FROM k WHERE id = 1;
----
a

# DO UPDATE overwrites the existing row's columns.
statement ok
INSERT INTO k VALUES (1, 'c') ON CONFLICT (id) DO UPDATE SET name = 'updated';

query T
SELECT name FROM k WHERE id = 1;
----
updated

# A non-conflicting insert with ON CONFLICT still inserts normally.
statement ok
INSERT INTO k VALUES (2, 'two') ON CONFLICT (id) DO NOTHING;

query IT rowsort
SELECT id, name FROM k;
----
1	updated
2	two

# DO UPDATE can reference the existing row's own columns in the assignment.
statement ok
INSERT INTO k VALUES (2, 'x') ON CONFLICT (id) DO UPDATE SET name = name;

query T
SELECT name FROM k WHERE id = 2;
----
two

# A plain conflicting insert (no ON CONFLICT) is still a duplicate-key error.
statement error
INSERT INTO k VALUES (1, 'dup');
