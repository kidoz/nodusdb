# Phase 6 (advanced): JSON / JSONB.

statement ok
CREATE TABLE docs (id INT PRIMARY KEY, data JSONB);

statement ok
INSERT INTO docs VALUES (1, '{"name": "alice", "age": 30}'), (2, '{"name": "bob", "age": 25}');

# ->> extracts a field as text
query T
SELECT data ->> 'name' FROM docs WHERE id = 1;
----
alice

# NOTE: `->>`/`->` work in the target list but NOT in a WHERE predicate — the
# planner turns `data ->> 'name'` into a synthetic column-name string that
# doesn't resolve at eval time, so `WHERE data ->> 'name' = 'bob'` matches
# nothing. Tracked as a gap; fixing needs a structured JSON-access predicate
# operand rather than a name string.

# JSON containment (@>)
query I rowsort
SELECT id FROM docs WHERE data @> '{"name": "alice"}';
----
1
