# Phase 2 (date/time): NodusDB has no native temporal type (values live as text),
# so this characterizes what works. ISO-8601 dates compare/sort lexically the
# same as chronologically, so ranges and ordering are expected to work.

statement ok
CREATE TABLE events (id INT PRIMARY KEY, d DATE, ts TIMESTAMP);

statement ok
INSERT INTO events VALUES (1, '2024-01-15', '2024-01-15 10:30:00'), (2, '2024-03-20', '2024-03-20 14:00:00'), (3, '2023-12-01', '2023-12-01 08:15:00');

# round-trip a DATE column
query IT
SELECT id, d FROM events ORDER BY id;
----
1	2024-01-15
2	2024-03-20
3	2023-12-01

# round-trip a TIMESTAMP column
query T
SELECT ts FROM events WHERE id = 1;
----
2024-01-15 10:30:00

# range filter (ISO text compares chronologically)
query I rowsort
SELECT id FROM events WHERE d > '2024-01-01';
----
1
2

# ORDER BY a date column
query I
SELECT id FROM events ORDER BY d;
----
3
1
2

# BETWEEN on dates
query I rowsort
SELECT id FROM events WHERE d BETWEEN '2024-01-01' AND '2024-02-01';
----
1

# NOT BETWEEN
query I rowsort
SELECT id FROM events WHERE d NOT BETWEEN '2024-01-01' AND '2024-02-01';
----
2
3

# a DATE literal as a WHERE operand
query I rowsort
SELECT id FROM events WHERE d > DATE '2024-01-01';
----
1
2

# MIN / MAX over dates
query TT
SELECT min(d), max(d) FROM events;
----
2023-12-01	2024-03-20

# cast text -> date
query T
SELECT '2024-06-15'::date;
----
2024-06-15

# DATE typed literal
query T
SELECT DATE '2024-06-15';
----
2024-06-15

# EXTRACT from ISO date/timestamp text (year/month/day/hour)
query I
SELECT EXTRACT(YEAR FROM DATE '2024-06-15');
----
2024

query I
SELECT EXTRACT(MONTH FROM DATE '2024-06-15');
----
6

query I
SELECT EXTRACT(DAY FROM DATE '2024-06-15');
----
15

query I
SELECT EXTRACT(YEAR FROM d) FROM events WHERE id = 2;
----
2024

query I
SELECT EXTRACT(HOUR FROM ts) FROM events WHERE id = 1;
----
10

# date +/- INTERVAL (real calendar math on the ISO text)
query T
SELECT DATE '2024-01-31' + INTERVAL '1 day';
----
2024-02-01

query T
SELECT DATE '2024-01-15' + INTERVAL '1 month';
----
2024-02-15

query T
SELECT DATE '2024-06-15' - INTERVAL '10 days';
----
2024-06-05

query T
SELECT DATE '2024-01-01' + INTERVAL '1 year';
----
2025-01-01

query T
SELECT TIMESTAMP '2024-01-15 10:30:00' + INTERVAL '2 hours';
----
2024-01-15 12:30:00

# interval offset on a date column
query T
SELECT d + INTERVAL '1 month' FROM events WHERE id = 1;
----
2024-02-15

# date_trunc
query T
SELECT date_trunc('month', TIMESTAMP '2024-03-15 10:30:00');
----
2024-03-01 00:00:00

query T
SELECT date_trunc('year', DATE '2024-06-15');
----
2024-01-01 00:00:00

query T
SELECT date_trunc('hour', TIMESTAMP '2024-03-15 10:30:45');
----
2024-03-15 10:00:00

# age (calendar interval, PostgreSQL text form)
query T
SELECT age(DATE '2024-03-15', DATE '2024-01-15');
----
2 mons

query T
SELECT age(DATE '2025-01-15', DATE '2024-01-15');
----
1 year

query T
SELECT age(DATE '2024-01-20', DATE '2024-01-15');
----
5 days

# INTERVAL literals normalize to canonical PostgreSQL text
query T
SELECT INTERVAL '1 day';
----
1 day

query T
SELECT INTERVAL '2 months 3 days';
----
2 mons 3 days

query T
SELECT INTERVAL '1 year';
----
1 year

# interval-typed column round-trip
statement ok
CREATE TABLE durations (id INT PRIMARY KEY, span INTERVAL);

statement ok
INSERT INTO durations VALUES (1, INTERVAL '5 days'), (2, INTERVAL '1 month');

query IT
SELECT id, span FROM durations ORDER BY id;
----
1	5 days
2	1 mon

# interval +/- interval
query T
SELECT INTERVAL '1 day' + INTERVAL '2 days';
----
3 days

query T
SELECT INTERVAL '2 months' + INTERVAL '10 days';
----
2 mons 10 days

query T
SELECT INTERVAL '5 days' - INTERVAL '2 days';
----
3 days

# interval comparison (by magnitude, not lexically)
query B
SELECT INTERVAL '10 days' > INTERVAL '2 days';
----
t

query B
SELECT INTERVAL '1 day' = INTERVAL '1 day';
----
t

# interval comparison in a WHERE predicate over a column
query I rowsort
SELECT id FROM durations WHERE span > INTERVAL '10 days';
----
2
