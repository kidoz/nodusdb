# Ported from PostgreSQL src/test/regress/sql/int8.sql (curated subset).
# Fixture and expected values follow expected/int8.out.

statement ok
CREATE TABLE int8_tbl (q1 BIGINT, q2 BIGINT);

statement ok
INSERT INTO int8_tbl VALUES
  (123, 456),
  (123, 4567890123456789),
  (4567890123456789, 123),
  (4567890123456789, 4567890123456789),
  (4567890123456789, -4567890123456789);

query II rowsort
SELECT q1, q2 FROM int8_tbl;
----
123	456
123	4567890123456789
4567890123456789	-4567890123456789
4567890123456789	123
4567890123456789	4567890123456789

query II rowsort
SELECT q1, q2 FROM int8_tbl WHERE q2 = 4567890123456789;
----
123	4567890123456789
4567890123456789	4567890123456789

query II rowsort
SELECT q1, q2 FROM int8_tbl WHERE q2 <> 4567890123456789;
----
123	456
4567890123456789	-4567890123456789
4567890123456789	123

query II rowsort
SELECT q1, q2 FROM int8_tbl WHERE q2 < 4567890123456789;
----
123	456
4567890123456789	-4567890123456789
4567890123456789	123

query II rowsort
SELECT q1, q2 FROM int8_tbl WHERE q1 < q2;
----
123	456
123	4567890123456789

query II rowsort
SELECT q1, q2 FROM int8_tbl WHERE q1 = q2;
----
4567890123456789	4567890123456789

# int8/int4 cross-type comparisons
query II rowsort
SELECT q1, q2 FROM int8_tbl WHERE q2 = 456;
----
123	456

query II rowsort
SELECT q1, q2 FROM int8_tbl WHERE 123 = q1;
----
123	456
123	4567890123456789

# arithmetic
query III rowsort
SELECT q1, q2, q1 + q2 AS plus FROM int8_tbl;
----
123	456	579
123	4567890123456789	4567890123456912
4567890123456789	-4567890123456789	0
4567890123456789	123	4567890123456912
4567890123456789	4567890123456789	9135780246913578

query II rowsort
SELECT q1, q1 % 2 FROM int8_tbl;
----
123	1
123	1
4567890123456789	1
4567890123456789	1
4567890123456789	1

# aggregates over int8
query I
SELECT sum(q1) FROM int8_tbl;
----
13703670370370613

query I
SELECT max(q2) FROM int8_tbl;
----
4567890123456789

query I
SELECT min(q2) FROM int8_tbl;
----
-4567890123456789

query I
SELECT count(*) FROM int8_tbl;
----
5
